# ─────────────────────────────────────────────────────────────
# Chikenhot API — variables de entorno
# Copia este archivo a .env y ajusta los valores.
# El archivo .env NO debe subirse al repositorio (ver .gitignore).
# ─────────────────────────────────────────────────────────────

# Entorno: "development" | "production"
# En "production" la app valida SECRET_KEY, exige DEBUG=False y CORS explícito.
ENVIRONMENT=development
DEBUG=true

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chikenhot_db

# JWT — GENERA UNO PROPIO PARA PRODUCCIÓN:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=tu-clave-secreta-super-segura-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — orígenes del frontend permitidos, separados por coma.
# Con credenciales activadas NO se admite "*".
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting de autenticación (login / registro) por IP
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
